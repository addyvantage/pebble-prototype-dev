{
  "name": "pebble_prototype",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "PORT=3001 npx tsx watch server/dev-server.ts",
    "dev:frontend": "vite --port 5173",
    "dev:full": "concurrently --kill-others-on-fail --names \"backend,frontend\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:kill": "kill $(lsof -ti :3001,:5173,:5174) 2>/dev/null || true",
    "smoke": "node scripts/dev_smoke_all.mjs",
    "smoke:runner-modes": "npx tsx scripts/runnerModesSmoke.ts",
    "test:function-mode": "npx tsx --test scripts/functionMode.test.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@aws-sdk/client-athena": "^3.1000.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1000.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1000.0",
    "@aws-sdk/client-dynamodb": "^3.1000.0",
    "@aws-sdk/client-eventbridge": "^3.1000.0",
    "@aws-sdk/client-lambda": "^3.1000.0",
    "@aws-sdk/client-polly": "^3.1000.0",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/client-sagemaker-runtime": "^3.1000.0",
    "@aws-sdk/client-sfn": "^3.1000.0",
    "@aws-sdk/lib-dynamodb": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/pdfkit": "^0.17.5",
    "amazon-cognito-identity-js": "^6.3.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "framer-motion": "^12.34.4",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.0",
    "lucide-react": "^0.551.0",
    "monaco-editor": "^0.55.1",
    "pdfkit": "^0.17.2",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "vite-plugin-node-polyfills": "^0.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
